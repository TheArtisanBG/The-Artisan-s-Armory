COPY_EXISTING ~C0HTD_01.SPL~ ~OVERRIDE/C0HTD_12.SPL~
LPF ALTER_EFFECT INT_VAR match_opcode = 0 match_power = 100 parameter1 = 1 END
COPY_EXISTING ~C0HTD_12.SPL~ ~OVERRIDE/C0HTD_14.SPL~
COPY_EXISTING ~C0HTD_12.SPL~ ~OVERRIDE/C0HTD_15.SPL~
COPY_EXISTING ~C0HTD_12.SPL~ ~OVERRIDE/C0HTD_16.SPL~
COPY_EXISTING ~C0HTD_12.SPL~ ~OVERRIDE/C0HTD_17.SPL~
COPY_EXISTING ~C0HTD_12.SPL~ ~OVERRIDE/C0HTD_18.SPL~
