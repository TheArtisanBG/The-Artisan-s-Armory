  COUNT_2DA_ROWS 4 rows
  FOR (index = 0 ; index < rows ; ++index) BEGIN
    SET_2DA_ENTRY index 3 4 0
  END
  PRETTY_PRINT_2DA
  BUT_ONLY
  
