
// DEXTERITY

COPY ~%MOD_FOLDER%/armor_class~ ~override~

COPY_EXISTING ~DEXMOD.2da~ ~override~
  COUNT_2DA_ROWS 4 rows
  FOR (index = 0 ; index < rows ; ++index) BEGIN
    SET_2DA_ENTRY index 3 4 0
  END
  PRETTY_PRINT_2DA
  BUT_ONLY
  
ACTION_IF NOT FILE_EXISTS_IN_GAME ~C0PASSEF.SPL~ THEN BEGIN
COPY ~%MOD_FOLDER%/spells/passive~ ~OVERRIDE~
END

ACTION_IF NOT FILE_EXISTS_IN_GAME ~C0PSEFCK.ITM~ THEN BEGIN
ACTION_IF FILE_EXISTS_IN_GAME ~baldur.bcs~ THEN BEGIN
EXTEND_TOP ~baldur.bcs~ ~%MOD_FOLDER%/scripts/passive_effects.baf~ EVAL
END
ACTION_IF FILE_EXISTS_IN_GAME ~bdbaldur.bcs~ THEN BEGIN
EXTEND_TOP ~bdbaldur.bcs~ ~%MOD_FOLDER%/scripts/passive_effects.baf~ EVAL
END
ACTION_IF FILE_EXISTS_IN_GAME ~baldur25.bcs~ THEN BEGIN
EXTEND_TOP ~baldur25.bcs~ ~%MOD_FOLDER%/scripts/passive_effects.baf~ EVAL
END
COPY_EXISTING ~SW1H01.ITM~ ~OVERRIDE/C0PSEFCK.ITM~
END

COPY_EXISTING ~C0PASSEF.SPL~ ~OVERRIDE~
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 0 parameter2 = 0 target = 3 timing = 1 STR_VAR resource = C0HTD_00 END

COPY_EXISTING ~C0HTD_D1.SPL~ ~OVERRIDE~
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 2 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_01 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 3 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_02 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 4 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_03 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 5 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_04 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 6 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_05 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 7 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_06 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 8 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_07 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 9 parameter2 = 123 target = 2 timing = 1 STR_VAR resource = C0HTD_08 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 15 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_15 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 16 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_16 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 17 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_17 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 18 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_18 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 19 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_19 END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 326 power = 100 parameter1 = 20 parameter2 = 122 target = 2 timing = 1 STR_VAR resource = C0HTD_20 END
